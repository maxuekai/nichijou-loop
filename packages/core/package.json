{
  "name": "@nichijou/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nichijou": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "start": "node dist/cli.js dev"
  },
  "dependencies": {
    "@nichijou/agent": "workspace:*",
    "@nichijou/ai": "workspace:*",
    "@nichijou/channel-wechat": "workspace:^",
    "@nichijou/shared": "workspace:*",
    "better-sqlite3": "^11.7.0",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.3",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node-cron": "^3.0.11"
  }
}
